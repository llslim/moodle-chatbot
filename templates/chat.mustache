{{!
    @template mod_geniai/chat

    Example context (json):
    {
        "geniainame": "Name",
        "manage_capability": true,
        "message_01": "string",
        "message_02": "string"
    }
}}

<div class="chat-container">
    <div id="geniai-mod-popup" data-student-name="{{student_name}}" data-course-name="{{course_name}}">
        <input type="hidden" id="local_geniai_message_01" value="{{message_01}}" />
        <input type="hidden" id="local_geniai_message_02" value="{{message_02}}" />

        <!-- Brand-new Premium Header with Persona Dropdown and Reset -->
        <div class="geniai-header-panel">
            <div class="geniai-brand">
                <span class="geniai-brand-icon">💬</span>
                <span class="geniai-brand-text">EDURA Simulator</span>
            </div>
            <div class="geniai-controls">
                <div class="geniai-dropdown-wrapper">
                    <select id="geniai-persona-select" class="geniai-select-dropdown">
                        <option value="" disabled {{^active_scenario}}selected{{/active_scenario}}>-- Select a Parent Persona --</option>
                        <option value="anna" {{#anna_selected}}selected{{/anna_selected}}>Anna Charles (Sarah's Mother - Autism)</option>
                        <option value="brianna" {{#brianna_selected}}selected{{/brianna_selected}}>Brianna Mitchell (Wesley's Mother - Apraxia)</option>
                        <option value="cathy" {{#cathy_selected}}selected{{/cathy_selected}}>Cathy Fratner (Charlie's Mother - Down Syndrome)</option>
                    </select>
                </div>
                <button id="geniai-generate-pdf" class="geniai-pdf-btn" title="Export conversation log to PDF">
                    Generate PDF
                </button>
                <button id="geniai-clear-history" class="geniai-clear-btn" title="{{#str}}clear_history_title,local_geniai{{/str}}">
                    Clear Chat
                </button>
            </div>
        </div>

        <div id="geniai-scrollarea">
            <div id="geniai-area-mensagens"></div>
        </div>

        <div id="geniai-sendarea">
            <textarea
                id="geniai-textarea"
                contenteditable="true"
                placeholder="{{#str}}write_message,local_geniai{{/str}}"
                rows="1"
            ></textarea>

            <div id="geniai-icon-stop" style="display: none" title="Stop">
                {{#pix}}icons/stop,local_geniai{{/pix}}
            </div>

            <div id="geniai-icon-mic" title="{{#str}}send_message,local_geniai{{/str}}">
                {{#pix}}icons/mic,local_geniai{{/pix}}
            </div>

            <div id="geniai-icon-send" title="{{#str}}send_message,local_geniai{{/str}}">
                {{#pix}}icons/send,local_geniai{{/pix}}
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        const target = document.getElementById("geniai-area-mensagens");
        if (!target) return;

        const applyLastClass = () => {
            const messages = target.querySelectorAll(".geniai-message");
            messages.forEach(msg => msg.classList.remove("last"));
            if (messages.length > 0) {
                messages[messages.length - 1].classList.add("last");
            }
        };

        const observer = new MutationObserver(applyLastClass);
        observer.observe(target, { childList: true, subtree: false });

        // Improved auto-resize textarea
        const textarea = document.getElementById("geniai-textarea");
        if (textarea) {
            let timeoutId;
            const resizeTextarea = () => {
                textarea.style.height = 'auto';
                const newHeight = Math.min(textarea.scrollHeight, 120);
                if (newHeight !== parseInt(textarea.style.height)) {
                    textarea.style.height = newHeight + 'px';
                }
            };

            textarea.addEventListener("input", () => {
                // Cancel the previous timeout
                if (timeoutId) {
                    clearTimeout(timeoutId);
                }
                // Set a new timeout
                timeoutId = setTimeout(resizeTextarea, 10);
            });

            // Initial resize
            resizeTextarea();
        }

        applyLastClass();
    })();
</script>

